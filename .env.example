# Credenciais do backend (Supabase). Copie para um arquivo .env e preencha.
# Encontre estes valores em: Supabase → Project Settings → API
# (a "anon public key" pode ficar exposta no frontend — é o padrão do Supabase)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key
